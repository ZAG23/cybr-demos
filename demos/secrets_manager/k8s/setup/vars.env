# Vault
USECASE_ID="$LAB_ID-poc-k8s"
SAFE_NAME="$USECASE_ID"

# SM Authenticator and K8s Namespace
SM_SERVICE_NAME="$USECASE_ID"
K8S_NAMESPACE="$USECASE_ID"
K8S_SERVICE_ACCOUNT="poc-service-account"

# The jwt claim value used to map to workload
JWT_CLAIM_IDENTITY="sub"
JWT_CLAIM_IDENTITY_VALUE="system:serviceaccount:$K8S_NAMESPACE:$K8S_SERVICE_ACCOUNT"

# Secrets IDs
SM_SECRET_1_ID="data/vault/$SAFE_NAME/account-ssh-user-1/username"
SM_SECRET_2_ID="data/vault/$SAFE_NAME/account-ssh-user-1/password"

# Secrets Var names to use in K8s
SM_SECRET_1_NAME="username"
SM_SECRET_2_NAME="password"

#Setup Automation
K8S_TYPE="rancher"
K8S_PUBLIC_KEYS="{{ .K8S_PUBLIC_KEYS }}"
K8S_JWKS_URI="{{ .K8S_JWKS_URI }}"
