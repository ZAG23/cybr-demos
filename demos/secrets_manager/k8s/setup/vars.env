# Vault
SAFE_NAME="poc-k8s"

# SM
# use the jwt claim value used to map to workload
JWT_CLAIM_IDENTITY="sub"
JWT_CLAIM_IDENTITY_VALUE="system:serviceaccount:poc-k8s:poc-service-account"

# K8s
SM_SERVICE_NAME="poc-k8s"

# Secrets IDs
SM_SECRET_1_ID="data/vault/poc-k8s/account-ssh-user-1/username"
SM_SECRET_2_ID="data/vault/poc-k8s/account-ssh-user-1/password"

# Var names to use in K8s
SM_SECRET_1_NAME="username"
SM_SECRET_2_NAME="password"

