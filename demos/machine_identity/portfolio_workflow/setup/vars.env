#------------------------------------------------------------------------------
# Demo Identity
USECASE_ID="$LAB_ID-machine-identity"
SAFE_NAME="$USECASE_ID"
#------------------------------------------------------------------------------
# Conjur Cloud / Secrets Manager
SM_SERVICE_NAME="$USECASE_ID"
SM_SECRET_DB_HOST_ID="data/vault/$SAFE_NAME/account-db-host/address"
SM_SECRET_DB_USER_ID="data/vault/$SAFE_NAME/account-db-user/username"
SM_SECRET_DB_PASS_ID="data/vault/$SAFE_NAME/account-db-user/password"
SM_SECRET_API_KEY_ID="data/vault/$SAFE_NAME/account-api-key/password"
#------------------------------------------------------------------------------
# Secrets Hub - AWS Target
SH_AWS_ACCOUNT_ID=""
SH_AWS_REGION="us-east-1"
SH_AWS_ROLE_NAME=""
SH_POLICY_NAME="$USECASE_ID-sync"
#------------------------------------------------------------------------------
# Secure Infrastructure Access
SIA_TARGET_HOST=""
SIA_TARGET_USER="ec2-user"
#------------------------------------------------------------------------------
# Certificate Option A: Conjur Cloud PKI (ephemeral workload certs)
PKI_COMMON_NAME="$USECASE_ID.demo.cyberark.cloud"
PKI_TTL="3600"
#------------------------------------------------------------------------------
# Certificate Option B: VCert Python SDK (programmatic cert lifecycle)
#   SaaS — set VCERT_API_KEY
VCERT_API_KEY=""
#   Self-Hosted/TPP — set VCERT_TPP_URL + one of token or user/pass
VCERT_TPP_URL=""
VCERT_TPP_USER=""
VCERT_TPP_PASSWORD=""
VCERT_TPP_ACCESS_TOKEN=""
#   Zone and subject (used by both SaaS and TPP)
VCERT_ZONE="Default"
VCERT_COMMON_NAME="$USECASE_ID.demo.cyberark.cloud"
VCERT_SAN_DNS="$VCERT_COMMON_NAME"
#------------------------------------------------------------------------------
# Certificate Option C: cert-manager + CyberArk Issuer (K8s-native automation)
#   Uses VCERT_API_KEY or VCERT_TPP_* from above for credentials
#   Falls back to self-signed issuer if none set
CM_NAMESPACE="$USECASE_ID"
CM_CERT_COMMON_NAME="$USECASE_ID.k8s.cyberark.cloud"
CM_CERT_SECRET_NAME="$USECASE_ID-tls"
#------------------------------------------------------------------------------
# Secure AI Agents (optional — skips if SAI_AGENT_NAME is empty)
SAI_AGENT_NAME=""
SAI_AGENT_TYPE="CUSTOM"
SAI_AGENT_DESCRIPTION="Machine Identity portfolio demo agent"
SAI_CALLBACK_URL="https://localhost:8443/callback"
#   AI Gateway — MCP Server registration (optional)
SAI_AIGW_SIA_MCP_URL=""
#   Example: "https://us-east-1-sia-db-mcp.adb.cyberark.cloud/mcp"
#------------------------------------------------------------------------------
