# Let's Encrypt
EMAIL="TO_BE_SET"
DOMAIN="TO_BE_SET"
ROUTE53_ZONE_ID="TO_BE_SET"

# Hashi Vault
NAMESPACE="hashi-vault"
#VAULT_FQDN="vault.domain.net"
VAULT_FQDN="TO_BE_SET"
# VAULT_PORT=":443"
VAULT_PORT="TO_BE_SET"

#VAULT_ADDR="https://vault.domain.net"
VAULT_ADDR="https://$VAULT_FQDN$VAULT_PORT"

VAULT_IMNIT_ADDR="SET_BY_SETUP"
VAULT_TOKEN="SET_BY_SETUP"
VAULT_KEY1="SET_BY_SETUP"
VAULT_KEY2="SET_BY_SETUP"
VAULT_KEY3="SET_BY_SETUP"

MOUNT_PATH="kv2"

# Secrets Hub Access
OIDC_DISCOVERY_URL="https://$TENANT_ID.id.cyberark.cloud/Secrets_Hub_OAuth2_server_application/"
VAULT_SKIP_VERIFY=true
ROLE_NAME="poc-sh-role"
POLICY_NAME="SecretsHubHashiVaultRolePolicy"